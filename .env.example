# Copy this file to .env and fill in your real Twitch app credentials.
# Get them at https://dev.twitch.tv/console/apps  (Manage -> Client ID / New Secret)
# NEVER commit the real .env file — it is gitignored.

TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here

# Optional: port for the local server (defaults to 3000)
# PORT=3000
